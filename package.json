{
  "name": "@grovs/mcp-server",
  "mcpName": "io.grovs/mcp",
  "version": "1.0.0",
  "description": "MCP server for managing deep links, attribution, analytics, campaigns, and app configuration on Grovs — an open-source, privacy-first alternative to Branch and AppsFlyer.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grovs-io/mcp.git"
  },
  "keywords": [
    "mcp",
    "deep-links",
    "mobile",
    "analytics",
    "attribution",
    "app-links",
    "universal-links",
    "mobile-attribution",
    "tracking-links",
    "campaigns",
    "grovs"
  ],
  "author": "Grovs",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/grovs-io/mcp/issues"
  },
  "homepage": "https://github.com/grovs-io/mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
